<FindBugsFilter>
    <!--  This rule is overly aggressive, marking classes which are in fact immutable, as mutable  -->
    <Match>
        <Bug pattern="EI_EXPOSE_REP2"/>
    </Match>
    <Match>
        <Bug pattern="EI_EXPOSE_REP"/>
    </Match>
    <!--  MongoCseManager constructor throws exceptions but has no finalizer, so no security risk  -->
    <Match>
        <Class name="com.gravity9.mongocse.MongoCseManager"/>
        <Bug pattern="CT_CONSTRUCTOR_THROW"/>
    </Match>
</FindBugsFilter>